# PostgreSQL — Neon
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=your-neon-password

# Redis — Upstash
SPRING_REDIS_HOST=<host>.upstash.io
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=your-upstash-password
SPRING_REDIS_SSL=true

# Elasticsearch — Bonsai
SPRING_ELASTICSEARCH_URIS=https://<host>.bonsaisearch.net
SPRING_ELASTICSEARCH_USERNAME=your-access-key
SPRING_ELASTICSEARCH_PASSWORD=your-access-secret

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:4200
